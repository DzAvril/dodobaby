# 使用 `npm run password:hash -- '你的家庭密码'` 生成；不要提交真实值。
DODOBABY_PASSWORD_HASH=scrypt:16384:8:1:replace-salt:replace-hash

# 至少 32 个随机字符，可使用 `openssl rand -hex 32` 生成。
DODOBABY_SESSION_SECRET=replace-with-at-least-32-random-characters

# 可选兼容项：设置页尚未管理 Agent 访问时使用的 Bearer token hash。
# 新部署建议登录后在“设置 → Agent / MCP 访问”中生成 token。
# 运行 `npm run agent:token` 可生成旧式环境变量配置；原始 token 只留在本机。
DODOBABY_AGENT_TOKEN_SHA256=replace-with-sha256-hash

# 必须与浏览器实际访问地址一致；公网部署请使用 HTTPS。
APP_URL=https://baby.example.com

# 可选；Web Push 默认复用 APP_URL。单独设置时必须使用公开域名，不能使用 localhost 或 .local。
# DODOBABY_VAPID_SUBJECT=mailto:notifications@example.com

# 映射到宿主机回环地址的端口，由现有反向代理转发。
DODOBABY_IMAGE=dz1874/dodobaby:latest
APP_HOST=127.0.0.1
APP_PORT=3000
